# ─── Database ─────────────────────────────────────────────────────────────────
# PostgreSQL connection string
# For local dev: postgresql://user:password@localhost:5432/meridian
# For production (Supabase/Neon/Railway/PlanetScale):
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/trendaxis?schema=public"

# ─── Auth ─────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
JWT_SECRET="replace-with-a-long-random-secret-at-least-32-chars"

# ─── Site ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# ─── Optional: Analytics & Ads ────────────────────────────────────────────────
# NEXT_PUBLIC_GA_ID="G-XXXXXXXXXX"
# NEXT_PUBLIC_ADSENSE_ID="ca-pub-XXXXXXXXXXXXXXXX"
